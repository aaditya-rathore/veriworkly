{
  "name": "veriworkly-resume",
  "version": "3.0.0",
  "private": true,
  "workspaces": [
    "apps/site",
    "apps/studio",
    "apps/blog-platform",
    "apps/docs-platform",
    "apps/server",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @veriworkly/site",
    "dev:site": "npm run dev -w @veriworkly/site",
    "dev:studio": "npm run dev -w @veriworkly/studio",
    "dev:server": "npm run dev -w @veriworkly/server",
    "dev:docs": "npm run dev -w @veriworkly/docs-platform -- -p 3001",
    "dev:blog": "npm run dev -w @veriworkly/blog-platform -- -p 3002",
    "dev:all": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:site": "npm run build -w @veriworkly/site",
    "build:studio": "npm run build -w @veriworkly/studio",
    "build:blog": "npm run build -w @veriworkly/blog-platform",
    "build:docs": "npm run build -w @veriworkly/docs-platform",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "generate:api": "npx @redocly/cli bundle apps/docs-platform/specs/openapi.yaml -o apps/docs-platform/openapi.yaml && node scripts/generate-api.mjs"
  },
  "devDependencies": {
    "@types/node": "^25",
    "eslint": "^9",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "typescript": "^6"
  }
}
