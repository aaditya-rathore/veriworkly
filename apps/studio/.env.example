# =========================================================
# 🎨 Frontend & API Configuration
# =========================================================

SITE_URL=

# Public API URL (used in browser/client-side code)
# Must start with NEXT_PUBLIC_ for frontend exposure
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080/api/v1

# Internal API URL
BACKEND_INTERNAL_URL=http://localhost:8080/api/v1


# =========================================================
# 👤 Admin Configuration
# =========================================================

# Should match the ADMIN_EMAIL in .env.docker and Backend .env for consistency across environments
# Admin email for system access / notifications
ADMIN_EMAIL=


# =========================================================
# 🔐 Security
# =========================================================

# Should match the AUTH_SECRET in .env.docker and Backend .env for consistency across environments
AUTH_SECRET=