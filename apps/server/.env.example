# =========================================================
# 🌐 Server Configuration
# =========================================================

NODE_ENV=development
PORT=8080
TRUST_PROXY=true

# Max in-memory entries (leave empty for default)
MAX_MEMORY_ENTRIES=

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:8080


# =========================================================
# 🗄 Database (Neon / Postgres)
# =========================================================

# Database connection string
DATABASE_URL=


# =========================================================
# ⚡ Redis (Cache)
# =========================================================

# Use either REDIS_URL OR REDIS_HOST + REDIS_PORT

REDIS_URL=
REDIS_HOST=
REDIS_PORT=


# =========================================================
# 🔌 API Keys (Optional Integrations)
# =========================================================

GITHUB_SYNC_ENABLED=false
GITHUB_TOKEN=
LINKEDIN_API_KEY=


# =========================================================
# 🔐 Security
# =========================================================

JWT_SECRET=

# Rate limiting (15 minutes window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100


# =========================================================
# 🪵 Logging
# =========================================================

LOG_LEVEL=info


# =========================================================
# 🔑 Authentication
# =========================================================

AUTH_SECRET=

# Base URL for auth callbacks
AUTH_BASE_URL=http://localhost:8080

# Session TTL (30 days)
AUTH_SESSION_TTL_SECONDS=2592000

# Reset TTL on activity (true | false)
AUTH_SESSION_RESET_TTL_ON_USE=true

# Enable session caching
AUTH_SESSION_CACHE_ENABLED=true

# Cache TTL (seconds)
AUTH_SESSION_CACHE_MAX_AGE_SECONDS=300

# OTP expiry (seconds)
AUTH_OTP_TTL_SECONDS=600

# Max OTP attempts
AUTH_OTP_ALLOWED_ATTEMPTS=3


# =========================================================
# 📧 Email Configuration
# =========================================================

ADMIN_EMAIL=
AUTH_EMAIL_FROM=

# Email provider (smtp, resend, etc.)
AUTH_EMAIL_PROVIDER=

# SMTP settings
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=
AUTH_SMTP_SECURE= # true | false
AUTH_SMTP_USER=
AUTH_SMTP_PASS=


# =========================================================
# 📊 Usage Metrics
# =========================================================

# Cron schedule (daily at 00:10)
USAGE_METRICS_FLUSH_CRON=10 0 * * *

USAGE_METRICS_FLUSH_TIMEZONE=


# =========================================================
# ⚡ Cache TTLs (seconds)
# =========================================================

ROADMAP_CACHE_TTL_SECONDS=
ROADMAP_STATS_CACHE_TTL_SECONDS=
ROADMAP_TAGS_CACHE_TTL_SECONDS=
GITHUB_STATS_CACHE_TTL_SECONDS=


# =========================================================
# 🐙 GitHub Sync (Scheduler)
# =========================================================

GITHUB_OWNER=
GITHUB_REPO=
GITHUB_PROJECT_URL=

# Runs twice daily
GITHUB_SYNC_CRON=0 0,12 * * *

GITHUB_SYNC_TIMEZONE=

# Internal API protection key
INTERNAL_SYNC_API_KEY=



# =========================================================
# 🚪 API Key Configuration
# =========================================================

hashSecret= "dev-api-key-secret"
authCacheTtlSeconds= 300
lastUsedTouchIntervalSeconds= 300
defaultRateLimit: 20
defaultScopes: user:read
defaultKeyLifetimeDays: 365
